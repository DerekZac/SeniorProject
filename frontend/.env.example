# =============================================================
# Crypton — Environment Configuration (12-Factor App: Factor III)
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
# =============================================================

# Application display name
VITE_APP_NAME=Crypton

# ── Live data sources (all free tiers work without keys) ──────

# CoinGecko Demo API key (optional — raises rate limit from ~5 to 30 req/min)
# Get one free at: https://www.coingecko.com/en/api
VITE_COINGECKO_API_KEY=

# CryptoCompare API key (optional — higher rate limits)
# Get one free at: https://www.cryptocompare.com/cryptopian/api-keys
VITE_CRYPTOCOMPARE_API_KEY=

# ── Custom backend (optional) ─────────────────────────────────
# If you deploy your own Python/Node backend for Reddit sentiment,
# set this URL and the frontend will route all requests through it.
VITE_API_URL=https://industrious-amazement-production.up.railway.app

# Python AI sentiment backend (FastAPI /classify endpoint).
# Defaults to the deployed Railway instance if unset.
VITE_PYTHON_API_URL=https://merry-stillness-production-b20d.up.railway.app
